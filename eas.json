{
  "cli": { "version": ">= 5.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://rastro-api-production-1941.up.railway.app"
      },
      "ios": { "simulator": false },
      "android": { "buildType": "apk" }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://rastro-api-production-1941.up.railway.app"
      },
      "ios": { "simulator": false },
      "android": { "buildType": "apk" }
    }
  },
  "submit": { "production": {} }
}
